# Supabase - same project as Campaign Engine
NEXT_PUBLIC_SUPABASE_URL=https://zyfkjxepykwpfzmkxitb.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_MARKETPLACE_URL=https://bahaymo.com

# Meta / Facebook
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# AI provider — "openai" (default) or "anthropic"
AI_PROVIDER=openai
OPENAI_API_KEY=your_openai_key
# Model override — defaults to gpt-4o; set to gpt-4o-mini to reduce cost
OPENAI_MODEL=gpt-4o
# Only needed when AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_key

# Creatomate
CREATOMATE_API_KEY=your_creatomate_key

# Fal.ai
FAL_API_KEY=your_fal_key
